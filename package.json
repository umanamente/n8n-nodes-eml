{
  "name": "n8n-nodes-eml",
  "version": "0.1.0",
  "description": "This is an n8n community node. It lets you parse and generate EML files (RFC 822) in your workflows.",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "Vasily Maslyukov",
    "email": "auro.coding@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/umanamente/n8n-nodes-eml.git"
  },
  "engines": {
    "node": ">=22.22.0",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "run-dev": "pnpm build && cross-env N8N_LOG_LEVEL=debug n8n start",
    "run-dev-tunnel": "pnpm build && cross-env N8N_LOG_LEVEL=debug n8n start --tunnel",
    "format": "prettier nodes --write",
    "lint": "eslint nodes package.json",
    "lintfix": "eslint nodes package.json --fix",
    "prepublishOnly": "pnpm build && eslint -c eslint.prepublish.config.cjs nodes package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/Eml/Eml.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/parser": "^8.57.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "gulp": "^5.0.1",
    "n8n-workflow": "^2.12.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "mailparser": "^3.9.4",
    "nodemailer": "^8.0.2"
  }
}
